<div id="providers-control" class="flex flex-col gap-2">
  <span class="label">Provider</span>
  <form action="/settings/set-provider" method="post">
    <select
      class="select-field"
      name="provider"
      hx-post="/settings/set-provider"
      hx-sync="#sidebar-controls:replace"
      hx-target="#workspace-main"
      hx-swap="outerHTML"
      hx-trigger="change"
    >
      <option <%= "selected" if provider == "deepseek" %> value="deepseek">DeepSeek</option>
      <option <%= "selected" if provider == "google" %> value="google">Google</option>
      <option <%= "selected" if provider == "openai" %> value="openai">OpenAI</option>
      <option <%= "selected" if provider == "anthropic" %> value="anthropic">Anthropic</option>
      <option <%= "selected" if provider == "xai" %> value="xai">xAI</option>
    </select>
  </form>
  <span class="theme-muted text-[11px]">5 providers available</span>
</div>
