<section
  id="jukebox"
  data-title="Jukebox"
  class="hidden px-5 pt-5"
>
  <div class="overflow-hidden rounded-[1.5rem] border shadow-[0_16px_36px_rgba(0,0,0,0.18)]" style="border-color: var(--theme-panel-border); background-color: color-mix(in srgb, var(--theme-panel) 92%, transparent);">
    <div class="flex items-center justify-between gap-3 border-b px-4 py-3" style="border-color: color-mix(in srgb, var(--theme-panel-border) 78%, transparent);">
      <div>
        <div class="label">Now Playing</div>
        <div id="jukebox-title" class="theme-strong jukebox-title mt-1 min-h-5 truncate text-sm font-medium tracking-tight"></div>
      </div>
      <div class="theme-muted text-[11px]">Music video</div>
    </div>
    <div
      id="jukebox-body"
      class="jukebox-body aspect-video overflow-hidden bg-black"
    >
      <div class="media-body flex h-full items-center justify-center px-4 text-sm">
        Ask for a list of songs to choose a music video
      </div>
    </div>
  </div>
</section>
