      <div class="min-w-0">
        <div class="text-lg font-semibold tracking-tight">MCP Servers</div>
      </div>
      <a class="mcp-nav-link" href="/" hx-get="/chat" hx-target="#chat-panel" hx-swap="outerHTML">Close</a>
